# EdTech LMS API Configuration
# Copy this file to .env and fill in your actual values

# Application Configuration
FORTYKAPICONFIG={"fortyk":{"api":{"applicationapikey":"your-256-character-api-key-here","accessexpirationminutes":60,"refreshexpirationminutes":1440,"changepasswordexpirationminutes":30,"verifyemailexpirationminutes":60,"port":3000,"applicationsecret":"your-application-secret-here","serversynckey":"your-server-sync-key-here","serverip":"127.0.0.1","servername":"localhost","applicationname":"LMS-API","debug":true,"database":{"name":"edtech_lms","user":"your-db-user","password":"your-db-password","host":"localhost","port":3306},"smtp":{"host":"smtp.gmail.com","port":587,"username":"your-email@gmail.com","password":"your-email-password","secure":false,"requiretsl":true,"emailfrom":"your-email@gmail.com"},"aws":{"accesskeyid":"your-aws-access-key","secretaccesskey":"your-aws-secret-key","s3bucketname":"your-s3-bucket-name","endpoint":"https://s3.amazonaws.com"},"rpi":{"RPIsecret":"your-rpi-secret","cloud":"your-cloud-endpoint"}},"ui":"http://localhost:3001"}}

# Database Configuration (Alternative format)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=edtech_lms
DB_USER=your-db-user
DB_PASSWORD=your-db-password

# JWT Configuration
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# AWS Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=your-s3-bucket-name
AWS_REGION=us-east-1

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password
SMTP_FROM=your-email@gmail.com

# Application Settings
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
